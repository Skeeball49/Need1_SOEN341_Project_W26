<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Planner — MealMajor</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .inline-icon {
      width: 1rem;
      height: 1rem;
      vertical-align: -0.15em;
      margin-right: 0.45rem;
      flex-shrink: 0;
    }
    .icon-label {
      display: inline-flex;
      align-items: center;
    }
    .meal-chip {
      background: rgba(91,201,255,0.12);
      border: 1px solid rgba(91,201,255,0.28);
      border-radius: 7px;
      padding: 5px 7px;
      margin-bottom: 4px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 4px;
    }
    .meal-chip span { font-size: 0.78rem; line-height: 1.3; }
    .meal-chip button {
      background: none;
      border: none;
      color: rgba(255,100,100,0.75);
      cursor: pointer;
      font-size: 0.75rem;
      padding: 0;
      flex-shrink: 0;
    }
    .meal-chip button:hover { color: #ff4d4d; }
    .planner-shell {
      transition: padding-right 0.28s ease;
    }
    .planner-drawer-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.46);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease;
      z-index: 39;
    }
    .planner-drawer {
      position: fixed;
      top: 94px;
      right: 24px;
      bottom: 24px;
      width: min(430px, calc(100vw - 32px));
      transform: translateX(calc(100% + 28px));
      transition: transform 0.28s ease;
      z-index: 40;
    }
    .planner-page.drawer-open .planner-drawer {
      transform: translateX(0);
    }
    .planner-page.drawer-open .planner-drawer-backdrop {
      opacity: 1;
      pointer-events: auto;
    }
    .planner-drawer-card {
      height: 100%;
      overflow-y: auto;
      margin: 0;
      display: flex;
      flex-direction: column;
    }
    .planner-drawer-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .planner-drawer-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      color: inherit;
      cursor: pointer;
      flex-shrink: 0;
    }
    .planner-drawer-close:hover {
      background: rgba(255,255,255,0.08);
    }
    .planner-drawer-toggle {
      position: fixed;
      top: 148px;
      right: 24px;
      z-index: 41;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(28, 26, 22, 0.96);
      color: inherit;
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.28);
      cursor: pointer;
      transition: right 0.28s ease, background 0.2s ease;
    }
    .planner-drawer-toggle:hover {
      background: rgba(38, 35, 29, 0.98);
    }
    .planner-page.drawer-open .planner-drawer-toggle {
      right: min(462px, calc(100vw - 24px));
    }
    @media (min-width: 1120px) {
      .planner-page.drawer-open .planner-shell {
        padding-right: 470px;
      }
    }
    @media (max-width: 720px) {
      .planner-drawer {
        top: auto;
        left: 12px;
        right: 12px;
        bottom: 12px;
        width: auto;
      }
      .planner-drawer-toggle {
        top: auto;
        bottom: 24px;
        right: 12px;
      }
      .planner-page.drawer-open .planner-drawer-toggle {
        right: 12px;
      }
    }
  </style>
</head>
<body class="planner-page drawer-open">
  <%- include("../partials/navbar") %>

  <div id="planner-drawer-backdrop" class="planner-drawer-backdrop" aria-hidden="true"></div>

  <button
    type="button"
    id="planner-drawer-toggle"
    class="planner-drawer-toggle"
    aria-controls="planner-drawer"
    aria-expanded="true"
  >
    <svg class="inline-icon" style="margin-right:0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h11.25M8.25 12h11.25M8.25 17.25h11.25M4.5 6.75h.008v.008H4.5V6.75Zm0 5.25h.008v.008H4.5V12Zm0 5.25h.008v.008H4.5v-.008Z" />
    </svg>
    <span id="planner-drawer-toggle-label">Hide Add Meal</span>
  </button>

  <aside id="planner-drawer" class="planner-drawer" aria-label="Add meal panel">
    <div class="split-card planner-drawer-card">
      <div class="planner-drawer-header">
        <h2 style="font-size:18px;font-weight:600;margin:0;">Add Meal</h2>
        <button type="button" id="planner-drawer-close" class="planner-drawer-close" aria-label="Hide add meal panel">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <% if (recipes.length === 0) { %>
        <p class="muted">No recipes yet. <a href="/recipes/new">Create a recipe</a> first.</p>
      <% } else { %>
        <form method="POST" action="/planner/add" class="form">
          <input type="hidden" name="email" value="<%= user.email %>">
          <input type="hidden" name="week_start" value="<%= weekStart %>">

          <label>Day
            <select id="planner-day" name="day" required>
              <% days.forEach(d => { %><option value="<%= d %>"><%= d %></option><% }) %>
            </select>
          </label>

          <label>Meal Type
            <select id="planner-meal-type" name="meal_type" required>
              <% mealTypes.forEach(mt => { %><option value="<%= mt %>"><%= mt %></option><% }) %>
            </select>
          </label>

          <label>Recipe
            <select id="planner-recipe" name="recipe_id" required>
              <option value="">Choose a recipe</option>
              <% recipes.forEach(r => { %>
                <option value="<%= r.id %>">[<%= r.code %>] <%= r.title %></option>
              <% }) %>
            </select>
          </label>

          <button class="btn" type="submit">Add to Planner</button>
        </form>
      <% } %>
    </div>
  </aside>

  <main class="section planner-shell" id="planner-shell">

    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;padding:0 24px 20px">
      <div>
        <div class="medium-title">Week Planner</div>
        <p class="muted" style="margin-top:4px">Week of <strong><%= weekStart %></strong></p>
      </div>
      <div style="display:flex;gap:8px;">
        <a class="btn btn-secondary" href="/templates?email=<%= encodeURIComponent(user.email) %>">
          <span class="icon-label">
            <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h11.25M8.25 12h11.25M8.25 17.25h11.25M4.5 6.75h.008v.008H4.5V6.75Zm0 5.25h.008v.008H4.5V12Zm0 5.25h.008v.008H4.5v-.008Z" />
            </svg>
            Templates
          </span>
        </a>
        <a class="btn" href="/grocery?email=<%= encodeURIComponent(user.email) %>">
          <span class="icon-label">
            <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386a1.125 1.125 0 0 1 1.08.804L5.25 5.625m0 0h13.964a1.125 1.125 0 0 1 1.09 1.404l-1.2 4.5a1.125 1.125 0 0 1-1.09.846H7.106a1.125 1.125 0 0 1-1.09-.846L5.25 5.625Zm0 0L4.5 15.75m3.75 3.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm9 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
            Grocery List
          </span>
        </a>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert-success"><%= success %></div>
    <% } %>

    <div class="plan-wrap" style="padding:0 24px">
      <table class="plan-table">
        <thead>
          <tr>
            <th></th>
            <% days.forEach(d => { %><th><%= d %></th><% }) %>
          </tr>
        </thead>
        <tbody>
          <% mealTypes.forEach(mt => { %>
            <tr>
              <td><%= mt %></td>
              <% days.forEach(d => { %>
                <td>
                  <% if (grid[d][mt].length > 0) { %>
                    <% grid[d][mt].forEach(entry => { %>
                      <div class="meal-chip">
                        <span><%= entry.recipe_title %></span>
                        <form method="POST" action="/planner/remove" style="margin:0;display:inline;">
                          <input type="hidden" name="email" value="<%= user.email %>">
                          <input type="hidden" name="entry_id" value="<%= entry.id %>">
                          <button type="submit" title="Remove" aria-label="Remove meal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.1">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                            </svg>
                          </button>
                        </form>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="pca">+</div>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div style="padding:20px 24px;display:flex;gap:10px;">
      <a class="btn btn-secondary" href="/dashboard">
        <span class="icon-label">
          <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6 4.5 12l6 6" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15" />
          </svg>
          Dashboard
        </span>
      </a>
      <a class="btn btn-secondary" href="/recipes">Manage Recipes</a>
    </div>

  </main>

  <script>
    const daySelect = document.getElementById('planner-day');
    const mealTypeSelect = document.getElementById('planner-meal-type');
    const recipeSelect = document.getElementById('planner-recipe');
    const drawerToggle = document.getElementById('planner-drawer-toggle');
    const drawerClose = document.getElementById('planner-drawer-close');
    const drawerBackdrop = document.getElementById('planner-drawer-backdrop');
    const drawerToggleLabel = document.getElementById('planner-drawer-toggle-label');
    
    const grid = <%- JSON.stringify(grid) %>;
    const allRecipes = <%- JSON.stringify(recipes) %>;

    function setDrawerOpen(isOpen) {
      document.body.classList.toggle('drawer-open', isOpen);
      if (drawerToggle) drawerToggle.setAttribute('aria-expanded', String(isOpen));
      if (drawerToggleLabel) drawerToggleLabel.textContent = isOpen ? 'Hide Add Meal' : 'Show Add Meal';
    }
    
    function updateRecipeOptions() {
      const selectedDay = daySelect.value;
      const selectedMealType = mealTypeSelect.value;
      
      const usedRecipeIds = new Set();
      if (grid[selectedDay] && grid[selectedDay][selectedMealType]) {
        grid[selectedDay][selectedMealType].forEach(entry => {
          usedRecipeIds.add(entry.recipe_id);
        });
      }
      
      recipeSelect.innerHTML = '<option value="">Choose a recipe</option>';
      allRecipes.forEach(recipe => {
        if (!usedRecipeIds.has(recipe.id)) {
          const option = document.createElement('option');
          option.value = recipe.id;
          option.textContent = `[${recipe.code}] ${recipe.title}`;
          recipeSelect.appendChild(option);
        }
      });
    }
    
    if (daySelect && mealTypeSelect && recipeSelect) {
      daySelect.addEventListener('change', updateRecipeOptions);
      mealTypeSelect.addEventListener('change', updateRecipeOptions);
      updateRecipeOptions();
    }

    if (drawerToggle) {
      drawerToggle.addEventListener('click', () => {
        setDrawerOpen(!document.body.classList.contains('drawer-open'));
      });
    }

    if (drawerClose) {
      drawerClose.addEventListener('click', () => setDrawerOpen(false));
    }

    if (drawerBackdrop) {
      drawerBackdrop.addEventListener('click', () => setDrawerOpen(false));
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setDrawerOpen(false);
      }
    });
  </script>
</body>
</html>
