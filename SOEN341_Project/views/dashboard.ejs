<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <%- include("../partials/navbar") %>

  <main class="container">
    <section class="section">
      <h1>Welcome back <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle;">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg></h1>
      <p class="muted">Here's your profile overview.</p>

      <div class="card-grid">

        <div class="feature-card">
          <h3>Email</h3>
          <p><%= user.email %></p>
        </div>

        <div class="feature-card">
          <h3>Diet Preference</h3>
          <p><%= user.diet %></p>
        </div>

        <div class="feature-card">
          <h3>Allergies</h3>
          <p><%= user.allergies %></p>
        </div>

      </div>

      <div style="margin-top:30px">
        <a class="btn" href="/">Back to home</a>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>