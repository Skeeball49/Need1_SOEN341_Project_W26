<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome — MealMajor</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="onb-body">
  <%
    const allergyIcons = {
      Nuts: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 8.25c0-2.485 1.515-4.5 3.75-4.5s3.75 2.015 3.75 4.5-1.515 6-3.75 6-3.75-3.515-3.75-6Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 14.25c-2.485 0-4.5 1.515-4.5 3.75S7.265 21.75 9.75 21.75s6-1.515 6-3.75-3.515-3.75-6-3.75Z"/></svg>',
      Shellfish: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12c2.5-3 5.5-4.5 9-4.5 2.5 0 4.75.75 6.75 2.25-2 1.5-4.25 2.25-6.75 2.25-3.5 0-6.5 1.5-9 4.5 0-1.5.5-3 1.5-4.5-1-1.5-1.5-3-1.5-4.5Z"/></svg>',
      Dairy: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5h6l1.5 3v10.5a1.5 1.5 0 0 1-1.5 1.5h-6A1.5 1.5 0 0 1 7.5 18V7.5l1.5-3Z"/></svg>',
      Gluten: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75v16.5M8.25 6.75c1.5 0 2.25.75 2.25 2.25S9.75 11.25 8.25 11.25M15.75 8.25c-1.5 0-2.25.75-2.25 2.25s.75 2.25 2.25 2.25M8.25 14.25c1.5 0 2.25.75 2.25 2.25S9.75 18.75 8.25 18.75"/></svg>',
      Eggs: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21c3.107 0 5.625-2.35 5.625-5.25 0-4.52-3.188-9.292-5.625-12-2.437 2.708-5.625 7.48-5.625 12C6.375 18.65 8.893 21 12 21Z"/></svg>',
      Soy: '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 8.25c0-2.485 1.515-4.5 3.75-4.5s3.75 2.015 3.75 4.5-1.515 6-3.75 6-3.75-3.515-3.75-6Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 14.25c-2.485 0-4.5 1.515-4.5 3.75S7.265 21.75 9.75 21.75s6-1.515 6-3.75-3.515-3.75-6-3.75Z"/></svg>'
    };
    const dietIcons = {
      Vegan: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 14.25c0-5.25 2.25-8.25 6.75-9 0 4.5-1.5 7.5-4.5 9 1.5.75 3.75 1.125 6.75 1.125-1.5 1.5-3.75 2.25-6.75 2.25-1.5 0-2.625-.375-3.375-1.125.75-.75 1.125-1.875 1.125-3.375Z"/></svg>',
      "High-Protein": '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m7.5 15 3-6 3 3 3-6"/><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5h15"/></svg>',
      Balanced: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75v16.5M6 8.25h12M7.5 8.25 5.25 13.5h4.5L7.5 8.25Zm9 0-2.25 5.25h4.5L16.5 8.25Z"/></svg>',
      Keto: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 12c0-4.143 2.5-7.125 6.75-8.25 1.5 3.75.75 7.125-2.25 10.125.75.375 1.688.563 2.813.563 1.125 0 2.063-.188 2.812-.563-.75 3-2.813 4.5-6.188 4.5-2.625 0-4.312-.563-5.063-1.688.75-.75 1.125-2.313 1.125-4.688Z"/></svg>',
      "No Preference": '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h7.5M6 10.5h12M4.5 14.25h15M5.25 18h13.5"/></svg>'
    };
    const checkIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>';
    const handoffIcons = {
      welcome: '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25 14.4 8.1l5.85 2.4-5.85 2.4L12 18.75l-2.4-5.85-5.85-2.4 5.85-2.4L12 2.25Z"/></svg>',
      open: '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="8.25"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75c2.25 2.25 3.375 5 3.375 8.25S14.25 18 12 20.25C9.75 18 8.625 15.25 8.625 12S9.75 6 12 3.75ZM3.75 12h16.5"/></svg>'
    };
  %>

  <div class="onb-wrap">

    <!-- Brand -->
    <div class="onb-brand">Meal<em>Major</em></div>

    <!-- Progress dots -->
    <div class="onb-progress">
      <div class="onb-dot active" id="dot-0"></div>
      <div class="onb-dot" id="dot-1"></div>
      <div class="onb-dot" id="dot-2"></div>
    </div>

    <!-- Single form wrapping all steps -->
    <form action="/onboarding" method="POST" id="onb-form">
      <input type="hidden" name="email" value="<%= user.email %>">
      <input type="hidden" name="diet" id="diet-input" value="">
      <input type="hidden" name="allergies" id="allergies-input" value="">

      <!-- ── Step 1: Allergies ── -->
      <div class="onb-slide active" id="slide-0">
        <div class="onb-header">
          <div class="onb-eyebrow">Step 1 of 3</div>
          <h1 class="onb-title">Any food allergies?</h1>
          <p class="onb-sub">We'll keep these out of your meal recommendations.</p>
        </div>

        <div class="allergy-grid">
          <div class="allergy-tile" data-value="Nuts">
            <div class="allergy-emoji"><%- allergyIcons.Nuts %></div>
            <div class="allergy-label">Nuts</div>
          </div>
          <div class="allergy-tile" data-value="Shellfish">
            <div class="allergy-emoji"><%- allergyIcons.Shellfish %></div>
            <div class="allergy-label">Shellfish</div>
          </div>
          <div class="allergy-tile" data-value="Dairy">
            <div class="allergy-emoji"><%- allergyIcons.Dairy %></div>
            <div class="allergy-label">Dairy</div>
          </div>
          <div class="allergy-tile" data-value="Gluten">
            <div class="allergy-emoji"><%- allergyIcons.Gluten %></div>
            <div class="allergy-label">Gluten</div>
          </div>
          <div class="allergy-tile" data-value="Eggs">
            <div class="allergy-emoji"><%- allergyIcons.Eggs %></div>
            <div class="allergy-label">Eggs</div>
          </div>
          <div class="allergy-tile" data-value="Soy">
            <div class="allergy-emoji"><%- allergyIcons.Soy %></div>
            <div class="allergy-label">Soy</div>
          </div>
        </div>

        <div class="onb-actions">
          <button type="button" class="onb-none-btn" id="none-allergies-btn">None of these</button>
          <button type="button" class="btn onb-next-btn" id="next-0">Continue →</button>
        </div>
      </div>

      <!-- ── Step 2: Diet ── -->
      <div class="onb-slide" id="slide-1">
        <div class="onb-header">
          <div class="onb-eyebrow">Step 2 of 3</div>
          <h1 class="onb-title">What's your eating style?</h1>
          <p class="onb-sub">Choose what fits you best — you can change this anytime.</p>
        </div>

        <div class="diet-grid">
          <div class="diet-card" data-value="Vegan"
            style="background-image:url('https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=600&q=80')">
            <div class="diet-card-overlay"></div>
            <div class="diet-card-body">
              <div class="diet-card-icon"><%- dietIcons.Vegan %></div>
              <div class="diet-card-name">Plant-based</div>
              <div class="diet-card-desc">Vegan &amp; vegetarian</div>
            </div>
            <div class="diet-card-check"><%- checkIcon %></div>
          </div>
          <div class="diet-card" data-value="High-Protein"
            style="background-image:url('https://images.unsplash.com/photo-1467003909585-2f8a72700288?auto=format&fit=crop&w=600&q=80')">
            <div class="diet-card-overlay"></div>
            <div class="diet-card-body">
              <div class="diet-card-icon"><%- dietIcons["High-Protein"] %></div>
              <div class="diet-card-name">High Protein</div>
              <div class="diet-card-desc">Meat, fish &amp; gains</div>
            </div>
            <div class="diet-card-check"><%- checkIcon %></div>
          </div>
          <div class="diet-card" data-value="Balanced"
            style="background-image:url('https://images.unsplash.com/photo-1490645935967-10de6ba17061?auto=format&fit=crop&w=600&q=80')">
            <div class="diet-card-overlay"></div>
            <div class="diet-card-body">
              <div class="diet-card-icon"><%- dietIcons.Balanced %></div>
              <div class="diet-card-name">Balanced</div>
              <div class="diet-card-desc">A bit of everything</div>
            </div>
            <div class="diet-card-check"><%- checkIcon %></div>
          </div>
          <div class="diet-card" data-value="Keto"
            style="background-image:url('https://images.unsplash.com/photo-1574484284002-952d92456975?auto=format&fit=crop&w=600&q=80')">
            <div class="diet-card-overlay"></div>
            <div class="diet-card-body">
              <div class="diet-card-icon"><%- dietIcons.Keto %></div>
              <div class="diet-card-name">Low Carb / Keto</div>
              <div class="diet-card-desc">High fat, low carbs</div>
            </div>
            <div class="diet-card-check"><%- checkIcon %></div>
          </div>
          <div class="diet-card" data-value="No Preference"
            style="background-image:url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=600&q=80')">
            <div class="diet-card-overlay"></div>
            <div class="diet-card-body">
              <div class="diet-card-icon"><%- dietIcons["No Preference"] %></div>
              <div class="diet-card-name">No Preference</div>
              <div class="diet-card-desc">Open to anything</div>
            </div>
            <div class="diet-card-check"><%- checkIcon %></div>
          </div>
        </div>

        <div class="onb-actions">
          <button type="button" class="onb-back-btn" id="back-1">← Back</button>
          <button type="button" class="btn onb-next-btn" id="next-1">Continue →</button>
        </div>
      </div>

      <!-- ── Step 3: Handoff ── -->
      <div class="onb-slide" id="slide-2">
        <div class="onb-handoff">
          <div class="onb-handoff-icon" id="handoff-icon"><%- handoffIcons.welcome %></div>
          <h1 class="onb-title" id="handoff-title">You're all set!</h1>
          <p class="onb-sub" id="handoff-sub">We'll personalise your meal plan based on your preferences.</p>
          <div class="onb-summary" id="onb-summary"></div>
        </div>

        <div class="onb-actions">
          <button type="button" class="onb-back-btn" id="back-2">← Back</button>
          <button type="submit" class="btn onb-submit-btn">Let's start cooking →</button>
        </div>
      </div>

    </form>
  </div>

  <script>
    const slides = document.querySelectorAll('.onb-slide');
    const dots   = document.querySelectorAll('.onb-dot');
    let current  = 0;

    // ── Allergy selection ──
    const selectedAllergies = new Set();
    document.querySelectorAll('.allergy-tile').forEach(tile => {
      tile.addEventListener('click', () => {
        const val = tile.dataset.value;
        if (selectedAllergies.has(val)) {
          selectedAllergies.delete(val);
          tile.classList.remove('selected');
        } else {
          selectedAllergies.add(val);
          tile.classList.add('selected');
        }
        syncAllergiesInput();
      });
    });

    document.getElementById('none-allergies-btn').addEventListener('click', () => {
      selectedAllergies.clear();
      document.querySelectorAll('.allergy-tile').forEach(t => t.classList.remove('selected'));
      syncAllergiesInput();
      goTo(1);
    });

    function syncAllergiesInput() {
      document.getElementById('allergies-input').value = [...selectedAllergies].join(', ');
    }

    // ── Diet selection (single) ──
    let selectedDiet = '';
    document.querySelectorAll('.diet-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.diet-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        selectedDiet = card.dataset.value;
        document.getElementById('diet-input').value = selectedDiet;
      });
    });

    // ── Navigation ──
    function goTo(n) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = n;
      slides[current].classList.add('active');
      dots[current].classList.add('active');

      if (current === 2) buildHandoff();
    }

    document.getElementById('next-0').addEventListener('click', () => goTo(1));
    document.getElementById('next-1').addEventListener('click', () => goTo(2));
    document.getElementById('back-1').addEventListener('click', () => goTo(0));
    document.getElementById('back-2').addEventListener('click', () => goTo(1));

    // ── Handoff content ──
    function buildHandoff() {
      const name = '<%= user.email.split("@")[0] %>';
      const allergies = [...selectedAllergies];
      const diet = selectedDiet;
      const icon  = document.getElementById('handoff-icon');
      const title = document.getElementById('handoff-title');
      const sub   = document.getElementById('handoff-sub');
      const sum   = document.getElementById('onb-summary');

      const chips = [];

      if (diet && diet !== 'No Preference') {
        chips.push(`<span class="onb-chip onb-chip-diet">${diet}</span>`);
      }
      if (allergies.length > 0) {
        allergies.forEach(a => chips.push(`<span class="onb-chip onb-chip-allergy">${a} free</span>`));
      }

      if (!diet && allergies.length === 0) {
        icon.innerHTML    = `<%- handoffIcons.open %>`;
        title.textContent = 'Wide open palate!';
        sub.textContent   = 'We\'ll surface popular recipes and learn your taste as you plan meals.';
        sum.innerHTML = '';
      } else {
        icon.innerHTML    = `<%- handoffIcons.welcome %>`;
        title.textContent = `You're all set, ${name}!`;
        sub.textContent   = 'Your feed will be tailored to your preferences from day one.';
        sum.innerHTML = chips.join('');
      }
    }
  </script>
</body>
</html>
