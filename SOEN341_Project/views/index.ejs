<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MealMajor — Plan meals. Eat better.</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="page-transition"></div>
  <div class="bg-blur"></div>
  <%-include("../partials/navbar") %>

  <main class="container">

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-left">
        <div class="badge" id="heroBadge">MealMajor</div>
        <h1 id="heroHeadline">Plan meals faster.<br/>Eat better.</h1>
        <p class="lead" id="heroLead">
          Organize recipes, build meal plans, track groceries and budget —
          built for people who actually want to eat well.
        </p>

        <div class="hero-ctas" id="heroCtas">
          <a class="btn btn-accent btn-lg" href="/register">Get started</a>
          <a class="btn btn-ghost btn-lg" href="/login">I already have an account</a>
        </div>

        <div class="mini-stats" id="heroStats">
          <div class="stat">
            <div class="stat-top">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="stat-title">Quick planning</div>
            <div class="muted">Weekly grid view</div>
          </div>
          <div class="stat">
            <div class="stat-top">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
              </svg>
            </div>
            <div class="stat-title">Diet aware</div>
            <div class="muted">Prefs and allergies</div>
          </div>
          <div class="stat">
            <div class="stat-top">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <div class="stat-title">Budget friendly</div>
            <div class="muted">Track cost per week</div>
          </div>
        </div>
      </div>

      <div class="hero-right" id="heroRight">
        <div class="preview-card">
          <div class="preview-head">
            <div>
              <div class="preview-title">This Week</div>
            </div>
            <span class="chip">Planner</span>
          </div>
          <div class="week-grid">
            <div class="cell head">Mon</div><div class="cell head">Tue</div><div class="cell head">Wed</div>
            <div class="cell head">Thu</div><div class="cell head">Fri</div><div class="cell head">Sat</div><div class="cell head">Sun</div>

            <div class="cell">Oats</div><div class="cell">Egg wrap</div><div class="cell">Smoothie</div>
            <div class="cell">Yogurt</div><div class="cell">Porridge</div><div class="cell">Toast</div><div class="cell">Pancakes</div>

            <div class="cell">Chicken bowl</div><div class="cell">Pasta</div><div class="cell">Salad</div>
            <div class="cell">Rice + tuna</div><div class="cell">Stir-fry</div><div class="cell">Wrap</div><div class="cell">Soup</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features Bento ────────────────────────────────────── -->
    <section id="features" class="section">
      <div class="section-head">
        <h2>Everything you need to eat well</h2>
        <p class="muted">Plan, track, and discover — all in one place.</p>
      </div>

      <div class="bento">

        <!-- Meal Planner — wide card with mini preview -->
        <div class="bento-card bento-planner">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3>Meal Planner</h3>
          <p>Plan your entire week in a clean grid view. Breakfast, lunch, and dinner — all in one place.</p>
          <div class="bento-mini-week">
            <div class="bento-mini-cell day">Mon</div><div class="bento-mini-cell day">Tue</div>
            <div class="bento-mini-cell day">Wed</div><div class="bento-mini-cell day">Thu</div>
            <div class="bento-mini-cell day">Fri</div><div class="bento-mini-cell day">Sat</div>
            <div class="bento-mini-cell day">Sun</div>
            <div class="bento-mini-cell">Oats</div><div class="bento-mini-cell">Egg wrap</div>
            <div class="bento-mini-cell">Smoothie</div><div class="bento-mini-cell">Yogurt</div>
            <div class="bento-mini-cell">Porridge</div><div class="bento-mini-cell">Toast</div>
            <div class="bento-mini-cell">Pancakes</div>
          </div>
        </div>

        <!-- Recipe Library -->
        <div class="bento-card bento-recipes">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h3>Recipe Library</h3>
          <p>Save, organize, and browse your personal recipe collection with ease.</p>
        </div>

        <!-- Grocery List -->
        <div class="bento-card bento-grocery">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </div>
          <h3>Smart Grocery List</h3>
          <p>Auto-generate your shopping list straight from your weekly meal plan.</p>
        </div>

        <!-- Nutrition -->
        <div class="bento-card bento-nutrition">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h3>Nutrition Insights</h3>
          <p>Track calories and macros across your planned meals every week.</p>
        </div>

        <!-- Budget -->
        <div class="bento-card bento-budget">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3>Budget Tracker</h3>
          <p>Stay on budget and know exactly what your meals cost per week.</p>
        </div>

        <!-- Pantry -->
        <div class="bento-card bento-pantry">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
          </div>
          <h3>Pantry Tracker</h3>
          <p>Know what you already have at home before you head to the store.</p>
        </div>

        <!-- Recommendations — wide card -->
        <div class="bento-card bento-reco">
          <div class="bento-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <h3>Recommendations</h3>
          <p>Get personalized meal suggestions based on your dietary preferences, past meals, and what's already in your pantry.</p>
        </div>

      </div>
    </section>

    <!-- ── How it works ───────────────────────────────────────── -->
    <section id="how" class="section split" id="howSection">
      <div class="split-card">
        <h2>How it works</h2>
        <ol class="steps">
          <li><span class="num">1</span> Create an account</li>
          <li><span class="num">2</span> Add your preferences</li>
          <li><span class="num">3</span> Plan your week</li>
        </ol>
      </div>
      <div class="split-card">
        <h2>Why students like it</h2>
        <ul class="bullets">
          <li>Less time thinking "what do I eat?"</li>
          <li>More consistent, healthier meals</li>
          <li>Grocery and budget tracking all in one place</li>
        </ul>
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────── -->
    <section id="faq" class="section">
      <div class="section-head">
        <h2>FAQ</h2>
      </div>
      <div class="faq">
        <details>
          <summary>Is this connected to a database?</summary>
          <p class="muted">Yes, user data is persisted securely via Supabase.</p>
        </details>
        <details>
          <summary>Can I create an account?</summary>
          <p class="muted">Yes, registration and login are fully functional.</p>
        </details>
        <details>
          <summary>Is it free?</summary>
          <p class="muted">Completely free — built for students at Concordia University.</p>
        </details>
      </div>
    </section>

  </main>

  <%- include("../partials/footer") %>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="/transitions.js"></script>
  <script>
    gsap.registerPlugin(ScrollTrigger);

    // ── Hero entrance ──────────────────────────────────────────
    var heroTl = gsap.timeline({ delay: 0.2 });
    heroTl
      .fromTo('#heroBadge',
        { opacity: 0, y: -12 },
        { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' })
      .fromTo('#heroHeadline',
        { opacity: 0, y: 28 },
        { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' },
        '-=0.1')
      .fromTo('#heroLead',
        { opacity: 0, y: 18 },
        { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' },
        '-=0.25')
      .fromTo('#heroCtas',
        { opacity: 0, y: 14 },
        { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' },
        '-=0.2')
      .fromTo('#heroStats .stat',
        { opacity: 0, y: 16 },
        { opacity: 1, y: 0, stagger: 0.1, duration: 0.4, ease: 'power2.out' },
        '-=0.15')
      .fromTo('#heroRight',
        { opacity: 0, x: 30 },
        { opacity: 1, x: 0, duration: 0.6, ease: 'power2.out' },
        '-=0.5');

    // ── Bento cards scroll reveal ──────────────────────────────
    gsap.fromTo('.bento-card',
      { opacity: 0, y: 36 },
      {
        opacity: 1,
        y: 0,
        stagger: 0.08,
        duration: 0.55,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '.bento',
          start: 'top 82%'
        }
      }
    );

    // ── How it works ───────────────────────────────────────────
    gsap.fromTo('.split-card',
      { opacity: 0, y: 24 },
      {
        opacity: 1,
        y: 0,
        stagger: 0.15,
        duration: 0.5,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '.split',
          start: 'top 85%'
        }
      }
    );

    // ── FAQ ────────────────────────────────────────────────────
    gsap.fromTo('.faq details',
      { opacity: 0, y: 16 },
      {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.45,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '.faq',
          start: 'top 88%'
        }
      }
    );
  </script>

</body>
</html>
