<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — MealMajor</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="bg-blur"></div>
  <%- include("../partials/navbar") %>

  <main class="container">
    <section class="auth">
      <div class="auth-card">
        <div class="auth-top">
          <h1>Welcome back</h1>
          <p class="muted">Log in to continue.</p>
        </div>
        
        <% if (error) { %>
  <div style="
    background:#ff4d4d22;
    border:1px solid #ff4d4d;
    padding:12px;
    border-radius:10px;
    margin-bottom:15px;
    color:white;
  ">
    <%= error %>
  </div>
  <div style="margin-bottom:12px">
    <a href="/register">Create an account</a>
  </div>
<% }%>

        <form class="form" method="POST" action="/login">
  <label>
    Email
    <input name="email" type="email" placeholder="you@school.ca" required />
  </label>

  <label>
    Password
    <input name="password" type="password" placeholder="••••••••" required />
  </label>

  <button class="btn w-full btn-lg" type="submit">Login</button>
</form>

        <div class="auth-bottom">
          <span class="muted small">No account?</span>
          <a href="/register">Create one</a>
        </div>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>