<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nutrition — MealMajor</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .empty-state-icon {
      width: 2.5rem;
      height: 2.5rem;
      margin: 0 auto 10px;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <%- include("../partials/navbar") %>

  <main class="section">
    <div style="padding:0 24px 20px">
      <div class="eyebrow">Week of <%= weekStart %></div>
      <div class="medium-title">Nutrition</div>
    </div>

    <div style="padding:0 24px">
      
      <!-- Nutrition Stats -->
      <div>
        <% if (!weeklyStats) { %>
          <div class="split-card" style="text-align:center;padding:40px 24px;">
            <div class="empty-state-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12c1.75-3.5 4.404-5.25 7.5-5.25S17.75 8.5 19.5 12c-1.75 3.5-4.404 5.25-7.5 5.25S6.25 15.5 4.5 12Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75V3.75M12 17.25v3M7.5 12H4.5M19.5 12h-3"/>
              </svg>
            </div>
            <h2 style="margin:0 0 8px 0;">No meals planned</h2>
            <p class="muted">Plan your week to see nutritional breakdown.</p>
            <a class="btn" href="/planner?email=<%= encodeURIComponent(user.email) %>" style="margin-top:16px;">Go to Planner</a>
          </div>
        <% } else { %>
          <!-- Weekly Summary -->
          <div class="split-card" style="margin-bottom:16px;">
            <h2 style="margin:0 0 16px;">Weekly Summary</h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;">
              <div class="feature-card" style="text-align:center;">
                <h3 style="font-size:1.6rem;margin:0 0 4px;"><%= weeklyStats.calories %></h3>
                <p class="muted" style="margin:0;font-size:0.85rem;">Total Calories</p>
                <p class="muted" style="margin:4px 0 0;font-size:0.75rem;">~<%= Math.round(weeklyStats.calories / 7) %>/day</p>
              </div>
              <div class="feature-card" style="text-align:center;">
                <h3 style="font-size:1.6rem;margin:0 0 4px;"><%= weeklyStats.protein.toFixed(0) %>g</h3>
                <p class="muted" style="margin:0;font-size:0.85rem;">Protein</p>
                <p class="muted" style="margin:4px 0 0;font-size:0.75rem;">~<%= (weeklyStats.protein / 7).toFixed(0) %>g/day</p>
              </div>
              <div class="feature-card" style="text-align:center;">
                <h3 style="font-size:1.6rem;margin:0 0 4px;"><%= weeklyStats.carbs.toFixed(0) %>g</h3>
                <p class="muted" style="margin:0;font-size:0.85rem;">Carbs</p>
                <p class="muted" style="margin:4px 0 0;font-size:0.75rem;">~<%= (weeklyStats.carbs / 7).toFixed(0) %>g/day</p>
              </div>
              <div class="feature-card" style="text-align:center;">
                <h3 style="font-size:1.6rem;margin:0 0 4px;"><%= weeklyStats.fat.toFixed(0) %>g</h3>
                <p class="muted" style="margin:0;font-size:0.85rem;">Fat</p>
                <p class="muted" style="margin:4px 0 0;font-size:0.75rem;">~<%= (weeklyStats.fat / 7).toFixed(0) %>g/day</p>
              </div>
            </div>
          </div>

          <!-- Daily Breakdown -->
          <div class="split-card">
            <h2 style="margin:0 0 16px;">Daily Breakdown</h2>
            <div style="display:grid;gap:8px;">
              <% dailyBreakdown.forEach(day => { %>
                <div style="padding:12px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.10);border-radius:8px;">
                  <div style="display:grid;grid-template-columns:100px 1fr;gap:12px;align-items:center;">
                    <div style="font-weight:600;"><%= day.day %></div>
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;font-size:0.85rem;">
                      <div>
                        <span class="muted">Cal:</span> <strong><%= day.calories %></strong>
                        <% const calPercent = goals.daily_calories > 0 ? Math.round((day.calories / goals.daily_calories) * 100) : 0; %>
                        <span class="muted" style="font-size:0.75rem;">(<%= calPercent %>%)</span>
                      </div>
                      <div>
                        <span class="muted">P:</span> <strong><%= day.protein.toFixed(0) %>g</strong>
                        <% const proteinPercent = goals.daily_protein > 0 ? Math.round((day.protein / goals.daily_protein) * 100) : 0; %>
                        <span class="muted" style="font-size:0.75rem;">(<%= proteinPercent %>%)</span>
                      </div>
                      <div>
                        <span class="muted">C:</span> <strong><%= day.carbs.toFixed(0) %>g</strong>
                        <% const carbsPercent = goals.daily_carbs > 0 ? Math.round((day.carbs / goals.daily_carbs) * 100) : 0; %>
                        <span class="muted" style="font-size:0.75rem;">(<%= carbsPercent %>%)</span>
                      </div>
                      <div>
                        <span class="muted">F:</span> <strong><%= day.fat.toFixed(0) %>g</strong>
                        <% const fatPercent = goals.daily_fat > 0 ? Math.round((day.fat / goals.daily_fat) * 100) : 0; %>
                        <span class="muted" style="font-size:0.75rem;">(<%= fatPercent %>%)</span>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>

      <div class="split-card" style="margin-top:20px">
        <h2 style="font-size:18px;font-weight:600;margin-bottom:16px">Daily Goals</h2>
        <form action="/nutrition/goals" method="POST" class="form">
          <input type="hidden" name="email" value="<%= user.email %>">
          
          <label>
            Calories
            <input type="number" name="daily_calories" value="<%= goals.daily_calories %>" min="0" step="50">
          </label>

          <label>
            Protein (g)
            <input type="number" name="daily_protein" value="<%= goals.daily_protein %>" min="0" step="5">
          </label>

          <label>
            Carbs (g)
            <input type="number" name="daily_carbs" value="<%= goals.daily_carbs %>" min="0" step="10">
          </label>

          <label>
            Fat (g)
            <input type="number" name="daily_fat" value="<%= goals.daily_fat %>" min="0" step="5">
          </label>

          <button type="submit" class="btn">Update Goals</button>
        </form>
      </div>

    </div>

  </main>
</body>
</html>
