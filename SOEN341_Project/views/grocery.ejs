<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Grocery List — MealMajor</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    @media print {
      .topbar, .no-print, footer { display: none !important; }
      body { background: white; color: black; }
    }
    .inline-icon {
      width: 1rem;
      height: 1rem;
      vertical-align: -0.15em;
      margin-right: 0.45rem;
      flex-shrink: 0;
    }
    .icon-label {
      display: inline-flex;
      align-items: center;
    }
    .empty-state-icon {
      width: 2.5rem;
      height: 2.5rem;
      margin: 0 auto 10px;
      color: var(--muted);
    }
    .banner-icon {
      width: 1rem;
      height: 1rem;
      margin-right: 0.45rem;
      vertical-align: -0.15em;
    }
  </style>
</head>
<body>
  <%- include("../partials/navbar") %>

  <main class="section">

    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;padding:0 24px 20px">
      <div>
        <div class="medium-title">Grocery List</div>
        <p class="muted" style="margin-top:4px">Week of <strong><%= weekStart %></strong></p>
      </div>
      <div style="display:flex;gap:8px;" class="no-print">
        <a class="btn btn-secondary" href="/pantry?email=<%= encodeURIComponent(user.email) %>">
          <span class="icon-label">
            <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955a1.125 1.125 0 0 1 1.592 0L21.75 12M4.5 9.75V19.5A1.5 1.5 0 0 0 6 21h4.5v-4.875c0-.621.504-1.125 1.125-1.125h.75c.621 0 1.125.504 1.125 1.125V21H18a1.5 1.5 0 0 0 1.5-1.5V9.75" />
            </svg>
            Pantry
          </span>
        </a>
        <a class="btn btn-secondary" href="/planner?email=<%= encodeURIComponent(user.email) %>">
          <span class="icon-label">
            <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6 4.5 12l6 6" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15" />
            </svg>
            Planner
          </span>
        </a>
      </div>
    </div>

    <% if (groceryList.length === 0) { %>
      <div style="padding:0 24px">
        <div class="split-card" style="text-align:center;padding:60px 24px;">
          <div class="empty-state-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386a1.125 1.125 0 0 1 1.08.804L5.25 5.625m0 0h13.964a1.125 1.125 0 0 1 1.09 1.404l-1.2 4.5a1.125 1.125 0 0 1-1.09.846H7.106a1.125 1.125 0 0 1-1.09-.846L5.25 5.625Zm0 0L4.5 15.75m3.75 3.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm9 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
          </div>
          <% if (hasPlannedMeals) { %>
            <h2 style="margin:0 0 8px;font-size:20px">Your pantry already covers this week's plan</h2>
            <p class="muted">The grocery list is empty because everything on the planner is already in your pantry.</p>
            <a class="btn" href="/pantry?email=<%= encodeURIComponent(user.email) %>" style="margin-top:16px;">
              View Pantry
            </a>
          <% } else { %>
            <h2 style="margin:0 0 8px;font-size:20px">No meals planned yet</h2>
            <p class="muted">Add recipes to your planner and your grocery list will appear here.</p>
            <a class="btn" href="/planner?email=<%= encodeURIComponent(user.email) %>" style="margin-top:16px;">
              Go to Planner
            </a>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <div style="padding:0 24px">

        <div class="groc-banner" style="margin-bottom:20px">
          <svg class="banner-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Smart pantry integration — showing only items you need to buy
        </div>

        <div style="margin-bottom:20px;display:grid;grid-template-columns:repeat(2,1fr);gap:12px">
          <div class="stat-block">
            <div class="stat-label">Items to buy</div>
            <div class="stat-val" style="font-size:28px"><%= groceryList.length %></div>
          </div>
          <div class="stat-block accent-lime">
            <div class="stat-label">Est. cost</div>
            <div class="stat-val lime" style="font-size:28px">$<%= totalCost.toFixed(2) %></div>
          </div>
        </div>

        <div style="margin-bottom:20px;display:flex;gap:10px" class="no-print">
          <button class="btn" onclick="window.print()">
            <span class="icon-label">
              <svg class="inline-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5V4.875c0-.621.504-1.125 1.125-1.125h8.25c.621 0 1.125.504 1.125 1.125V7.5m-10.5 9v2.625c0 .621.504 1.125 1.125 1.125h8.25c.621 0 1.125-.504 1.125-1.125V16.5m-10.5 0h10.5M6 10.5H5.625A2.625 2.625 0 0 0 3 13.125v2.25A2.625 2.625 0 0 0 5.625 18H6m12-7.5h.375A2.625 2.625 0 0 1 21 13.125v2.25A2.625 2.625 0 0 1 18.375 18H18" />
              </svg>
              Print List
            </span>
          </button>
          <a class="btn btn-secondary" href="/planner?email=<%= encodeURIComponent(user.email) %>">Edit Meal Plan</a>
        </div>

        <!-- Ingredient list -->
        <div class="split-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <h2 style="margin:0;">Ingredients Needed</h2>
            <span class="chip"><%= groceryList.length %> items</span>
          </div>
          <p class="muted" style="margin:0 0 14px;">Quantities are consolidated across all planned recipes. Grouped by category for easier shopping.</p>
          
          <% const categories = Object.keys(groupedList).sort(); %>
          <% categories.forEach(category => { %>
            <div style="margin-bottom:20px;">
              <h3 style="font-size:0.95rem;margin:0 0 8px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;">
                <%= category %> (<%= groupedList[category].length %>)
              </h3>
              <div style="display:grid;gap:7px;">
                <% groupedList[category].forEach(item => { %>
                  <div class="grocery-item" style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.10);border-radius:10px;">
                    <div style="flex:1;">
                      <span style="text-transform:capitalize;font-weight:600;"><%= item.name %></span>
                      <% if (item.inPantry > 0) { %>
                        <div class="muted" style="font-size:0.8rem;margin-top:2px;">
                          Need <%= item.needed %>, have <%= item.inPantry %> in pantry
                        </div>
                      <% } %>
                    </div>
                    <span style="color:var(--muted);font-weight:700;font-size:0.9rem;">Buy: <%= item.toBuy %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>

      </div>
    <% } %>

  </main>

</body>
</html>
